#!/usr/bin/env bash
#
# post-merge hook — restart services when their project files change
#
# Maps project dirs to systemd service names.
# Add new entries as projects are created.
#

declare -A SERVICE_MAP=(
  ["projects/status-page"]="status-page"
  ["projects/todo-api"]="todo-api"
  ["projects/asteroids"]="asteroids"
  ["projects/drop"]="drop"
  ["projects/quiz"]="quiz"
)

# Get list of changed files in this merge
CHANGED=$(git diff-tree -r --name-only --no-commit-id ORIG_HEAD HEAD)

for project_dir in "${!SERVICE_MAP[@]}"; do
  service="${SERVICE_MAP[$project_dir]}"
  if echo "$CHANGED" | grep -q "^${project_dir}/"; then
    # Install/update pip dependencies if requirements.txt changed and venv exists
    if echo "$CHANGED" | grep -q "^${project_dir}/requirements.txt"; then
      if [ -d "${project_dir}/venv" ]; then
        echo "post-merge: ${project_dir}/requirements.txt changed, installing dependencies..."
        "${project_dir}/venv/bin/pip" install -r "${project_dir}/requirements.txt" 2>&1 && \
          echo "post-merge: dependencies installed." || \
          echo "post-merge: WARNING — failed to install dependencies for ${service}"
      fi
    fi
    echo "post-merge: ${project_dir} changed, restarting ${service}..."
    sudo systemctl restart "$service" 2>&1 && \
      echo "post-merge: ${service} restarted." || \
      echo "post-merge: WARNING — failed to restart ${service}"
  fi
done

# Flutter web projects are built and deployed by GitHub Actions
# (.github/workflows/build-flutter-web.yml) — nothing to do on the server.
