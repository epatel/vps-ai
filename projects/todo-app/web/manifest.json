{
    "name": "Todo App",
    "short_name": "Todos",
    "id": "/todo-app/",
    "start_url": ".",
    "display": "standalone",
    "background_color": "#1C1B1F",
    "theme_color": "#1C1B1F",
    "description": "Manage your tasks",
    "orientation": "portrait-primary",
    "prefer_related_applications": false,
    "share_target": {
        "action": "./share",
        "method": "POST",
        "enctype": "multipart/form-data",
        "params": {
            "title": "title",
            "text": "text",
            "url": "url",
            "files": [
                {
                    "name": "images",
                    "accept": ["image/*"]
                }
            ]
        }
    },
    "icons": [
        {
            "src": "icons/Icon-192.png",
            "sizes": "192x192",
            "type": "image/png"
        },
        {
            "src": "icons/Icon-512.png",
            "sizes": "512x512",
            "type": "image/png"
        },
        {
            "src": "icons/Icon-maskable-192.png",
            "sizes": "192x192",
            "type": "image/png",
            "purpose": "maskable"
        },
        {
            "src": "icons/Icon-maskable-512.png",
            "sizes": "512x512",
            "type": "image/png",
            "purpose": "maskable"
        }
    ]
}
