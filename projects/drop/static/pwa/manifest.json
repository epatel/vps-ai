{
    "name": "Drop",
    "short_name": "Drop",
    "description": "Instant phone-to-desktop sharing",
    "start_url": "/drop/pwa/",
    "scope": "/drop/",
    "display": "standalone",
    "background_color": "#1a1a2e",
    "theme_color": "#6c63ff",
    "icons": [
        {
            "src": "icon.svg",
            "sizes": "any",
            "type": "image/svg+xml"
        },
        {
            "src": "icon.svg",
            "sizes": "512x512",
            "type": "image/svg+xml",
            "purpose": "maskable"
        }
    ],
    "share_target": {
        "action": "/drop/share-target",
        "method": "POST",
        "enctype": "multipart/form-data",
        "params": {
            "title": "title",
            "text": "text",
            "url": "url",
            "files": [
                {
                    "name": "files",
                    "accept": ["image/*", "video/*", "application/*", "text/*"]
                }
            ]
        }
    }
}
